      "title": "Execution Outcomes Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "sum(rate(recovery_analytics_events_published_total[1m])) by (event_type, result)", "legendFormat": "{{event_type}} {{result}}", "refId": "A" }
      ],
      "title": "Analytics Publish Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "sum(rate(recovery_scheduler_outcomes_total[1m])) by (outcome)", "legendFormat": "{{outcome}}", "refId": "A" },
        { "expr": "sum(rate(recovery_attempts_dispatched_total[1m])) by (channel, result)", "legendFormat": "dispatch {{channel}} {{result}}", "refId": "B" }
      ],
      "title": "Scheduling And Dispatch Rate",
      "type": "timeseries"
    },
    {
