      "id": 2,
      "targets": [
        { "expr": "sum(rate(recovery_kafka_events_consumed_total[1m])) by (topic)", "legendFormat": "consumed {{topic}}", "refId": "A" },
        { "expr": "sum(rate(recovery_kafka_events_processed_total[1m])) by (topic)", "legendFormat": "processed {{topic}}", "refId": "B" }
      ],
      "title": "Consumer Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "sum(rate(recovery_kafka_producer_publish_total[1m])) by (topic, result)", "legendFormat": "{{topic}} {{result}}", "refId": "A" }
      ],
      "title": "Producer Publish Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
