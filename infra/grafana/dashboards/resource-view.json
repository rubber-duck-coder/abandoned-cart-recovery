{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        { "expr": "recovery_runtime_heap_used_bytes", "legendFormat": "heap", "refId": "A" },
        { "expr": "recovery_runtime_non_heap_used_bytes", "legendFormat": "non_heap", "refId": "B" }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "recovery_runtime_process_cpu_load_ratio", "legendFormat": "process_cpu", "refId": "A" }
      ],
      "title": "Process CPU Load",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "recovery_runtime_thread_count", "legendFormat": "threads", "refId": "A" }
      ],
      "title": "Thread Count",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        { "expr": "sum(rate(recovery_attempts_executed_total{outcome=~\"failed|suppressed_.*\"}[1m]))", "legendFormat": "terminal_errorish_rate", "refId": "A" },
        { "expr": "sum(rate(recovery_repository_operations_total{outcome=\"error\"}[1m]))", "legendFormat": "repository_error_rate", "refId": "B" },
        { "expr": "sum(rate(recovery_kafka_producer_publish_total{result=\"error\"}[1m]))", "legendFormat": "producer_error_rate", "refId": "C" }
      ],
      "title": "Failure And Error Rate",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["recovery", "resources"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
